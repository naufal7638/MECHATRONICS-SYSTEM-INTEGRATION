import serial
import time
import keyboard

# Change this to your Arduino port
arduino = serial.Serial('COM5', 9600, timeout=1)
time.sleep(2)  # Wait for Arduino to reset

print("RFID Reader active — Scan your card!\n")

try:
    rfid = ""
    while True:
        event = keyboard.read_event()
        if event.event_type == keyboard.KEY_DOWN:
            if event.name == 'enter':
                print(f"➡️  Sending RFID: {rfid}")
                arduino.write((rfid + '\n').encode())
                time.sleep(0.5)

                # Read Arduino response
                response = arduino.read_all().decode(errors='ignore').strip()
                if "Access Granted" in response:
                    print("✅ Access Granted!")
                elif "Invalid Card" in response or "Unknown" in response:
                    print("❌ Invalid card detected!")
                elif response:
                    print("Arduino:", response)
                rfid = ""
            else:
                rfid += event.name

except KeyboardInterrupt:
    print("\nProgram stopped.")
finally:
    arduino.close()
    print("🔌 Serial connection closed.")
